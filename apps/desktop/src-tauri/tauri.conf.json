{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Hardware Design Studio",
  "version": "0.1.0",
  "identifier": "studio.aihardware.design",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Hardware Design Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 720
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
